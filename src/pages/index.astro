---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Heatrow Club | Hip Hop & Trap Madrid">
	<!-- Navbar -->
	<nav class="fixed top-0 w-full bg-red-600 z-50 shadow-lg">
		<div class="max-w-7xl mx-auto px-4">
			<div class="flex justify-between items-center h-16">
				<a href="/" class="text-2xl font-black text-white tracking-tight">
					HEATROW CLUB
				</a>
				<div class="hidden md:flex gap-8">

					<a href="#entradas" class="text-white hover:text-gray-200 font-semibold transition-colors">
						ENTRADAS
					</a>
					
					<a href="#galeria" class="text-white hover:text-gray-200 font-semibold transition-colors">
						GALERÍA
					</a>
					<a href="#contacto" class="text-white hover:text-gray-200 font-semibold transition-colors">
						CONTACTO
					</a>
				</div>
			</div>
		</div>
	</nav>

	<!-- Hero Section -->
	<section id="evento" class="min-h-screen flex items-center justify-center relative bg-black pt-16">
		<div class="text-center px-4 max-w-5xl mx-auto">
			<h1 class="text-7xl md:text-9xl font-black mb-8 tracking-tighter text-white">
				HEATROW
			</h1>
			<div class="w-32 h-1 bg-red-600 mx-auto mb-8"></div>
			<p class="text-2xl md:text-4xl font-bold mb-6 text-red-600">
				CLUB
			</p>
			<p class="text-xl md:text-2xl mb-8 text-gray-300">
				THE MUSIC THEY DON'T PLAY
			</p>
			
			<!-- CTA Button -->
			<a 
				href="#entradas" 
				class="inline-block bg-red-600 hover:bg-red-700 text-white px-12 py-4 rounded-none text-xl font-bold transition-all duration-300 shadow-xl uppercase tracking-wider"
			>
				Consigue tus entradas
			</a>
		</div>
	</section>

	<!-- Info Section -->
	<section id="info" class="py-20 px-4 bg-black">
		<div class="w-full max-w-6xl mx-auto">
			<h2 class="text-4xl md:text-6xl font-black mb-16 text-center text-white">
				EL EVENTO
			</h2>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 w-full">
				<div class="bg-zinc-900 p-8 border-l-4 border-red-600 hover:bg-zinc-800 transition-colors w-full">
					<h3 class="text-2xl font-bold mb-4 text-red-600 uppercase">Música</h3>
					<p class="text-gray-300 leading-relaxed">
						Los mejores beats de Hip Hop y Trap americano. DJs residentes que prenden la pista toda la noche.
					</p>
				</div>
				<div class="bg-zinc-900 p-8 border-l-4 border-red-600 hover:bg-zinc-800 transition-colors w-full">
					<h3 class="text-2xl font-bold mb-4 text-red-600 uppercase">Ambiente</h3>
					<p class="text-gray-300 leading-relaxed">
						La mejor energía de Madrid. Un público que vive la música al máximo en cada sesión.
					</p>
				</div>
				<div class="bg-zinc-900 p-8 border-l-4 border-red-600 hover:bg-zinc-800 transition-colors w-full">
					<h3 class="text-2xl font-bold mb-4 text-red-600 uppercase">Ubicación</h3>
					<p class="text-gray-300 leading-relaxed">
						En el corazón de Madrid. Fácil acceso y el mejor sistema de sonido de la ciudad.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Tickets Section -->
	<section id="entradas" class="py-20 px-4 bg-black border-t border-zinc-800">
		<div class="max-w-4xl mx-auto text-center">
			<h2 class="text-4xl md:text-6xl font-black mb-8 text-white">
				ENTRADAS
			</h2>
			<div class="w-32 h-1 bg-red-600 mx-auto mb-12"></div>
			<p class="text-xl mb-12 text-gray-400">
				Próximamente disponible la compra online
			</p>
			<div class="bg-zinc-900 p-10 border-2 border-red-600 inline-block">
				<p class="text-2xl font-bold text-white mb-4 uppercase">
					Venta de entradas
				</p>
				<p class="text-gray-400">
					Sistema de compra en desarrollo
				</p>
			</div>
		</div>
	</section>

	<!-- Footer -->
	<footer class="py-12 px-4 bg-black border-t border-red-600">
		<div class="max-w-6xl mx-auto text-center">
			<h3 class="text-2xl font-bold mb-6 text-white">SÍGUENOS</h3>
			<div class="flex justify-center items-center gap-8 mb-8">
				<!-- Instagram -->
				<a 
					href="https://www.instagram.com/heatrow.club/" 
					target="_blank"
					rel="noopener noreferrer"
					class="text-white hover:text-red-600 transition-colors"
					aria-label="Instagram de Heatrow"
				>
					<svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
						<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
					</svg>
				</a>
				<!-- Spotify -->
				<a 
					href="https://open.spotify.com/playlist/5eJiyavYY1wixGm6BrLJY9?pi=rIy92VewTh282" 
					target="_blank"
					rel="noopener noreferrer"
					class="text-white hover:text-red-600 transition-colors"
					aria-label="Spotify de Heatrow"
				>
					<svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
						<path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
					</svg>
				</a>
			</div>
			<p class="text-gray-600 text-sm">
				© 2026 Heatrow Club. Madrid.
			</p>
		</div>
	</footer>
</Layout>
